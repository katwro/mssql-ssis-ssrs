  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="FinRecoverDS">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=localhost;Initial Catalog=FinRecover</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>c577b909-c9d4-46af-8c3d-67010d38fdba</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DebtsDataSet">
      <Query>
        <DataSourceName>FinRecoverDS</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@status">
            <Value>=Parameters!status.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    c.ClientNumber,
	c.FirstName + ' ' + c.LastName AS ClientName,
    d.DebtNumber,
    d.Amount,
    d.DebtDate,
    d.Description,
    ds.Status,
    ds.ChangedAt
FROM 
    Debts d
JOIN Clients c ON d.ClientID = c.ClientID
JOIN DebtStatusHistory ds ON d.DebtID = ds.DebtID
WHERE 
    ds.Status = @status</CommandText>
      </Query>
      <Fields>
        <Field Name="ClientNumber">
          <DataField>ClientNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ClientName">
          <DataField>ClientName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Amount">
          <DataField>Amount</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="DebtNumber">
          <DataField>DebtNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DebtDate">
          <DataField>DebtDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Status">
          <DataField>Status</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ChangedAt">
          <DataField>ChangedAt</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>FinRecoverDS</DataSourceName>
        <CommandText>  select distinct [status],[status] as name from  [DebtStatusHistory]</CommandText>
      </Query>
      <Fields>
