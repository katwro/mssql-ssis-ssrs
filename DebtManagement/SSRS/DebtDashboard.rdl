  <DataSets>
    <DataSet Name="TotalAmount">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT 
    (SELECT SUM(Amount) FROM Debts) 
    - 
    (SELECT SUM(AmountPaid) FROM Payments) AS TotalAmount</CommandText>
      </Query>
      <Fields>
        <Field Name="TotalAmount">
          <DataField>TotalAmount</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ActiveDebts">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>  SELECT COUNT(*) AS ActiveDebts
FROM Debts d
JOIN (
    SELECT DebtID, MAX(ChangedAt) AS LastChange
    FROM DebtStatusHistory
    GROUP BY DebtID
) dh ON d.DebtID = dh.DebtID
JOIN DebtStatusHistory h ON dh.DebtID = h.DebtID AND dh.LastChange = h.ChangedAt
WHERE h.Status != 'paid'</CommandText>
      </Query>
      <Fields>
        <Field Name="ActiveDebts">
          <DataField>ActiveDebts</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DebtByStatus">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>	  SELECT 
		h.Status, 
		COUNT(DISTINCT d.DebtID) AS CountDebts
	FROM Debts d
	JOIN (
		SELECT DebtID, MAX(ChangedAt) AS LastChange
		FROM DebtStatusHistory
		GROUP BY DebtID
	) dh ON d.DebtID = dh.DebtID
	JOIN DebtStatusHistory h ON dh.DebtID = h.DebtID AND dh.LastChange = h.ChangedAt
	GROUP BY h.Status
	having h.Status!='paid'</CommandText>
      </Query>
      <Fields>
        <Field Name="Status">
          <DataField>Status</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CountDebts">
          <DataField>CountDebts</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="CountByMonth">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT 
    FORMAT(DebtDate, 'yyyy-MM') AS DebtMonth,
   
    COUNT(*) AS DebtCount
FROM Debts
GROUP BY FORMAT(DebtDate, 'yyyy-MM'), Status
ORDER BY DebtMonth</CommandText>
      </Query>
      <Fields>
        <Field Name="DebtMonth">
          <DataField>DebtMonth</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DebtCount">
          <DataField>DebtCount</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
