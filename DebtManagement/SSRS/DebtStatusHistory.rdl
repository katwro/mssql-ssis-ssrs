  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=localhost;Initial Catalog=FinRecover</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>4db63419-627f-4a78-9981-bc50c8d93003</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DebtNumber">
            <Value>=Parameters!DebtNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    dsh.ChangedAt, 
    dsh.Status, 
    dsh.ChangedBy
FROM 
    DebtStatusHistory dsh
INNER JOIN Debts d ON dsh.DebtID = d.DebtID
WHERE 
    (@DebtNumber IS NULL OR d.DebtNumber LIKE '%' + @DebtNumber + '%')
ORDER BY 
    dsh.ChangedAt DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ChangedAt">
          <DataField>ChangedAt</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="Status">
          <DataField>Status</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ChangedBy">
          <DataField>ChangedBy</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
