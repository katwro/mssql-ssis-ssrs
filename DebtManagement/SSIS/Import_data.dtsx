        <SQLTask:SqlTaskData
          SQLTask:Connection="{20C4A15C-5A5C-4A9B-BCF3-D6B6EA0EB54F}"
          SQLTask:BypassPrepare="False"
          SQLTask:SqlStatementSource="  MERGE INTO Clients AS Target&#xA;USING Stg_Clients AS Source&#xA;    ON Target.Pesel = Source.Pesel&#xA;WHEN MATCHED THEN&#xA;    UPDATE SET&#xA;Target.FirstName = Source.FirstName,&#xA;        Target.LastName = Source.LastName,&#xA;        Target.Email = Source.Email,&#xA;Target.PhoneNumber = Source.PhoneNumber&#xA;WHEN NOT MATCHED BY TARGET THEN&#xA;    INSERT (FirstName,LastName, Email, PhoneNumber,Pesel,ClientNumber)&#xA;    VALUES (Source.FirstName, Source.LastName, Source.Email, Source.PhoneNumber, Source.Pesel,Source.ClientNumber);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
